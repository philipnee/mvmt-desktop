{
  "name": "mvmt-desktop",
  "version": "0.0.1",
  "private": true,
  "description": "Desktop control surface for the local mvmt engine",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "preview": "electron-vite preview",
    "vendor:mvmt": "bash scripts/sync-mvmt.sh",
    "vendor:cloudflared": "bash scripts/fetch-cloudflared.sh",
    "vendor:cloudflared:all": "bash scripts/fetch-cloudflared.sh all",
    "vendor": "npm run vendor:mvmt && npm run vendor:cloudflared",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "build": {
    "appId": "app.mvmt.desktop",
    "productName": "mvmt",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json",
      "!**/{*.map,*.ts,*.tsx,tsconfig*.json}"
    ],
    "asar": true,
    "extraResources": [
      { "from": "vendor/mvmt/dist", "to": "mvmt/dist" },
      { "from": "vendor/mvmt/package.json", "to": "mvmt/package.json" },
      { "from": "vendor/mvmt/node_modules", "to": "mvmt/node_modules" },
      {
        "from": "vendor/cloudflared/${platform}-${arch}",
        "to": "cloudflared/${platform}-${arch}",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        { "target": "dmg", "arch": ["arm64"] },
        { "target": "zip", "arch": ["arm64"] }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "signAndEditExecutable": false
    },
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }],
      "category": "Utility"
    },
    "dmg": {
      "writeUpdateInfo": false
    },
    "publish": null
  },
  "dependencies": {
    "lucide-react": "^1.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.3"
  }
}
